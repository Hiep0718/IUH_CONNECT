# ===========================
# IUH Connect - Full-Stack .gitignore
# Java/Spring Boot + React Native
# ===========================

# ---------- Java / Maven ----------
*.class
*.jar
*.war
*.ear
*.log
target/
!.mvn/wrapper/maven-wrapper.jar
!gradle-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ---------- Maven Wrapper ----------
.mvn/wrapper/maven-wrapper.jar

# ---------- Spring Boot ----------
*.pid
*.gz
*.tmp

# ---------- IntelliJ IDEA ----------
.idea/
*.iws
*.iml
*.ipr
out/

# ---------- Eclipse ----------
.classpath
.project
.settings/
bin/

# ---------- VS Code ----------
.vscode/
*.code-workspace

# ---------- Node / React Native ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.yarn/
.pnp.*

# React Native
frontend/android/app/build/
frontend/android/.gradle/
frontend/android/build/
frontend/android/local.properties
frontend/ios/Pods/
frontend/ios/build/
*.xcworkspace
*.xcuserdata
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Metro Bundler
.metro-health-check*

# ---------- Docker ----------
docker-compose.override.yml

# ---------- Environment / Secrets ----------
.env
.env.*
!.env.example

# ---------- OS Files ----------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.swp
*.swo
*~
