# =============================================
# IUH Connect — Environment Variables Template
# Copy this file to .env and fill in real values
# =============================================

# ---------- JWT Secret ----------
JWT_SECRET=IUHConnectSuperSecretKeyForJWT2024MustBeAtLeast256BitsLong!!

# ---------- MariaDB ----------
MARIADB_ROOT_PASSWORD=root123
MARIADB_DATABASE=auth_db
MARIADB_USER=iuh_user
MARIADB_PASSWORD=iuh_pass

# ---------- MongoDB ----------
MONGO_ROOT_USERNAME=iuh_admin
MONGO_ROOT_PASSWORD=iuh_mongo_pass
MONGO_DATABASE=iuh_connect_db

# ---------- Redis ----------
REDIS_PASSWORD=iuh_redis_pass

# ---------- AWS S3 ----------
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=iuh-connect-chat-media
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ---------- MinIO (Local Object Storage) ----------
MINIO_ROOT_USER=iuh_minio_admin
MINIO_ROOT_PASSWORD=iuh_minio_password
